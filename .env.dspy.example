# DSPy provider environment for Spark Researcher.
#
# Copy this file to `.env.dspy.local` and fill in the values you want to use.
# Spark does not auto-load dotenv files, so load it in PowerShell before running DSPy-related commands:
#
#   Get-Content .env.dspy.local | ForEach-Object {
#     if ($_ -match '^\s*#' -or $_ -match '^\s*$') { return }
#     $name, $value = $_ -split '=', 2
#     Set-Item -Path "Env:$name" -Value $value
#   }
#
# OpenAI-compatible provider example:
OPENAI_API_KEY=replace-with-your-provider-key
OPENAI_BASE_URL=https://replace-with-your-openai-compatible-endpoint/v1
SPARK_STARTUP_DSPY_MODEL=openai/replace-with-your-model-id

# Typical Spark Researcher settings:
PYTHONPATH=C:\Users\USER\Desktop\spark-researcher\src
