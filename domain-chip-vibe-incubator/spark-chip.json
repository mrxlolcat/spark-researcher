        "local_services",
        "ecommerce_ops",
        "creators"
      ],
      "distribution_engine": [
        "operator_content",
        "warm_outbound",
        "design_partner_network",
        "community_loops",
        "portfolio_crosssell"
      ],
      "build_stack": [
        "template_factory",
        "agent_workflows",
        "custom_apps",
        "human_in_loop_ops",
