{
  "candidate_trials": [
    {
      "candidate_id": "baseline",
      "candidate_summary": "Run the current config without mutation.",
      "hypothesis": "The baseline defines the current local floor.",
      "mutations": {}
    },
    {
      "candidate_id": "lr-0003",
      "candidate_summary": "Move learning rate toward the known optimum.",
      "hypothesis": "A lower learning rate should improve val_loss.",
      "mutations": {
        "learning_rate": "0.0003"
      }
    },
    {
      "candidate_id": "wd-002",
      "candidate_summary": "Move weight decay toward the known optimum.",
      "hypothesis": "A slightly higher weight decay should improve val_loss.",
      "mutations": {
        "weight_decay": "0.02"
      }
    }
  ],
  "commands": {
    "train": {
      "args": [
        "python",
        "train.py"
      ],
      "cwd": ".",
      "kind": "train-once",
      "log_name": "train.log"
    }
  },
  "eval_goal": "minimize",
  "eval_metric": "val_loss",
  "guardrails": {
    "blocked_command_fragments": [
      "shutdown",
      "format",
      "reg delete",
      "Remove-Item",
      "del /f",
      "rm -rf"
    ],
    "consecutive_discard_limit": 3,
    "max_loop_iterations": 8,
    "require_clean_git_for_self_edit": true,
    "require_human_approval_for_self_edit": true
  },
  "metrics": {
    "training_seconds": {
      "kind": "float",
      "pattern": "^training_seconds:\\s+([0-9.]+)$"
    },
    "val_loss": {
      "kind": "float",
      "pattern": "^val_loss:\\s+([0-9.]+)$"
    }
  },
  "mutable_parameters": [
    {
      "description": "Local file-based learning-rate mutation.",
      "file": "config.json",
      "name": "learning_rate",
      "pattern": "\"learning_rate\":\\s*[0-9.]+",
      "template": "\"learning_rate\": {value}"
    },
    {
      "description": "Local file-based weight-decay mutation.",
      "file": "config.json",
      "name": "weight_decay",
      "pattern": "\"weight_decay\":\\s*[0-9.]+",
      "template": "\"weight_decay\": {value}"
    }
  ],
  "mutable_targets": [
    "src/spark_researcher",
    "docs",
    "README.md",
    "pyproject.toml"
  ],
  "project_name": "spark-researcher-demo",
  "project_root": "examples/toy-project",
  "self_edit": {
    "auto_push": true,
    "branch_prefix": "self-edit/",
    "command": [],
    "commit_message_template": "Apply self-edit proposal {proposal_id}",
    "git_mode": "branch",
    "main_branch": "main",
    "mutable_targets": [
      "src/spark_researcher",
      "docs",
      "README.md",
      "pyproject.toml"
    ],
    "prompt_preamble": "Keep the repo lightweight, transparent, and review-first."
  },
  "trainers": [
    {
      "compile_command": [
        "python",
        "trainer.py"
      ],
      "examples_path": "training_examples.jsonl",
      "max_examples": 200,
      "min_examples": 3,
      "name": "toy-compiler",
      "recompile_every": 2
    }
  ]
}
