{
  "candidate_trials": [
    {
      "candidate_id": "global-baseline",
      "candidate_summary": "Measure the disconnected baseline before any emulator-aware policy is trusted.",
      "hypothesis": "The baseline defines the floor before emulator-connected Pokemon policies are compared.",
      "mutations": {}
    },
    {
      "candidate_id": "speedrun-intro-boot",
      "candidate_summary": "Boot into a speedrun intro policy that mashes through opening text and movement setup.",
      "hypothesis": "A start-assisted wander opener should create the strongest intro baseline for later route tasks.",
      "mutations": {
        "benchmark_profile": "speedrun_intro",
        "policy_id": "wander",
        "startup_action": "start",
        "task_id": "intro_boot",
        "tick_stride": "24"
      }
    },
    {
      "candidate_id": "speedrun-leave-bedroom",
      "candidate_summary": "Bias toward fast room exit movement for the first route fragment.",
      "hypothesis": "A right-biased route policy should outperform symmetric wandering on the leave-bedroom task.",
      "mutations": {
        "benchmark_profile": "speedrun_route",
        "policy_id": "right_scout",
        "startup_action": "none",
        "task_id": "leave_bedroom",
        "tick_stride": "24"
      }
    }
  ],
  "chip": {
    "manifest": "spark-chip.json",
    "path": "."
  },
  "commands": {
    "research": {
      "args": [],
      "cwd": ".",
      "kind": "chip-evaluate",
      "log_name": "domain-chip-pokemon-player.log"
    }
  },
  "eval_goal": "maximize",
  "eval_metric": "pokemon_progress_score",
  "guardrails": {
    "blocked_command_fragments": [
      "shutdown",
      "format",
      "reg delete",
      "Remove-Item",
      "del /f",
      "rm -rf"
    ],
    "consecutive_discard_limit": 3,
    "max_loop_iterations": 8,
    "require_clean_git_for_self_edit": true,
    "require_human_approval_for_self_edit": true
  },
  "memory": {
    "backend": "local"
  },
  "metrics": {
    "emulator_connected": {
      "kind": "float",
      "pattern": "^emulator_connected:\\s+([0-9.]+)$"
    },
    "exploration_score": {
      "kind": "float",
      "pattern": "^exploration_score:\\s+([0-9.]+)$"
    },
    "interaction_score": {
      "kind": "float",
      "pattern": "^interaction_score:\\s+([0-9.]+)$"
    },
    "pokemon_progress_score": {
      "kind": "float",
      "pattern": "^pokemon_progress_score:\\s+([0-9.]+)$"
    },
    "screen_novelty": {
      "kind": "float",
      "pattern": "^screen_novelty:\\s+([0-9.]+)$"
    },
    "verdict_confidence": {
      "kind": "float",
      "pattern": "^verdict_confidence:\\s+([0-9.]+)$"
    }
  },
  "mutable_parameters": [],
  "mutable_targets": [
    "src/domain_chip_pokemon_player",
    "docs",
    "launch_pokemon_player.ps1",
    "README.md",
    "spark-chip.json",
    "pyproject.toml"
  ],
  "project_name": "domain-chip-pokemon-player",
  "project_root": ".",
  "self_edit": {
    "auto_push": false,
    "branch_prefix": "self-edit/",
    "command": [],
    "commit_message_template": "Apply self-edit proposal {proposal_id}",
    "git_mode": "manual",
    "main_branch": "main",
    "mutable_targets": [
      "src/domain_chip_pokemon_player",
      "docs",
      "launch_pokemon_player.ps1",
      "README.md",
      "spark-chip.json",
      "pyproject.toml"
    ],
    "prompt_preamble": "Keep the chip emulator-connected, benchmark-first, and honest about what it can and cannot prove yet."
  },
  "trainers": []
}
